{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "typeRoots": ["./node_modules/@types", "./src/types"],

    "module": "node16",
    "moduleResolution": "Node16",

    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["src", "tests"]
}
